# https://github.com/github/gitignore/blob/main/Python.gitignore

# Compiled source #
###################
__pycache__/
*.com
*.class 
# *$py.class
*.dll
*.exe
*.o
*.so
*.py[cod]

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

